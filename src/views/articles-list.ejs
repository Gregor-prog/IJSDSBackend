<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Published Articles - IJSDS</title>
  
  <meta name="description" content="Published academic research articles and archives of the International Journal for Social Work and Development Studies (IJSDS).">
  <link rel="canonical" href="<%= baseUrl %>/papers">

  <style>
    body {
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      line-height: 1.6;
      color: #222;
      background-color: #fcfcfc;
      margin: 0;
      padding: 0;
    }
    .container {
      max-width: 900px;
      margin: 40px auto;
      padding: 40px;
      background-color: #ffffff;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
      border-radius: 4px;
      border-top: 5px solid #800000;
    }
    header {
      border-bottom: 2px solid #eaeaea;
      padding-bottom: 24px;
      margin-bottom: 30px;
    }
    .journal-title {
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #800000;
      font-weight: 700;
      margin-bottom: 10px;
    }
    h1 {
      font-size: 2.2rem;
      color: #111;
      margin: 10px 0;
      font-weight: 800;
    }
    .articles-count {
      color: #666;
      font-size: 0.95rem;
    }
    .article-card {
      padding: 25px 0;
      border-bottom: 1px solid #eaeaea;
    }
    .article-card:last-child {
      border-bottom: none;
    }
    .article-title {
      font-size: 1.3rem;
      font-weight: 700;
      line-height: 1.3;
      margin: 0 0 10px 0;
    }
    .article-title a {
      color: #111;
      text-decoration: none;
      transition: color 0.15s;
    }
    .article-title a:hover {
      color: #800000;
      text-decoration: underline;
    }
    .article-authors {
      font-size: 0.95rem;
      font-weight: 500;
      color: #444;
      margin-bottom: 8px;
    }
    .article-meta {
      font-size: 0.85rem;
      color: #666;
      margin-bottom: 12px;
    }
    .article-abstract-excerpt {
      font-size: 0.92rem;
      color: #555;
      text-align: justify;
      margin-bottom: 15px;
    }
    .article-tags {
      font-size: 0.82rem;
      color: #777;
    }
    .tag {
      background-color: #f1f1f1;
      padding: 3px 8px;
      border-radius: 3px;
      margin-right: 5px;
      display: inline-block;
    }
    footer {
      text-align: center;
      margin-top: 50px;
      padding-top: 25px;
      border-top: 1px solid #eaeaea;
      font-size: 0.85rem;
      color: #777;
    }
    a {
      color: #800000;
      text-decoration: none;
    }
    a:hover {
      text-decoration: underline;
    }
    @media (max-width: 600px) {
      .container {
        margin: 0;
        padding: 20px;
        box-shadow: none;
        border-radius: 0;
      }
    }
  </style>
</head>
<body>

  <div class="container">
    <header>
      <div class="journal-title">International Journal for Social Work and Development Studies (IJSDS)</div>
      <h1>Published Articles & Archives</h1>
      <div class="articles-count">Showing <%= articles.length %> peer-reviewed articles</div>
    </header>

    <main>
      <% if (articles.length === 0) { %>
        <p>No published articles found in this archive.</p>
      <% } else { %>
        <% articles.forEach(function(article) { %>
          <article class="article-card">
            <h2 class="article-title">
              <a href="/papers/<%= article.id %>"><%= article.title %></a>
            </h2>
            <div class="article-authors">
              <%= formatAuthors(article.authors) %>
            </div>
            <div class="article-meta">
              Published: <%= formatDate(article.publication_date ?? article.created_at) %> | 
              <% if (article.volume) { %>Vol <%= article.volume %><% } %> 
              <% if (article.issue) { %>Issue <%= article.issue %><% } %> 
              <% if (article.crossrefDoi || article.doi) { %> | DOI: <a href="https://doi.org/<%= article.crossrefDoi || article.doi %>" target="_blank"><%= article.crossrefDoi || article.doi %></a><% } %>
            </div>
            <div class="article-abstract-excerpt">
              <%= article.abstract ? article.abstract.substring(0, 240) + '...' : '' %>
            </div>
            <% if (article.keywords && article.keywords.length > 0) { %>
              <div class="article-tags">
                <strong>Keywords:</strong> 
                <% article.keywords.forEach(function(keyword) { %>
                  <span class="tag"><%= keyword %></span>
                <% }); %>
              </div>
            <% } %>
          </article>
        <% }); %>
      <% } %>
    </main>

    <footer>
      &copy; <%= new Date().getFullYear() %> International Journal for Social Work and Development Studies (IJSDS). All Rights Reserved.<br>
      Licensed under <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank">Creative Commons Attribution 4.0 International License</a>.
    </footer>
  </div>

</body>
</html>
